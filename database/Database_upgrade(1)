  TABLES IN CORRECT ORDER 
IF OBJECT_ID('dbo.RecoveryJobs', 'U') IS NOT NULL DROP TABLE dbo.RecoveryJobs;
IF OBJECT_ID('dbo.Vehicles', 'U') IS NOT NULL DROP TABLE dbo.Vehicles;
IF OBJECT_ID('dbo.Owners', 'U') IS NOT NULL DROP TABLE dbo.Owners;
IF OBJECT_ID('dbo.Technicians', 'U') IS NOT NULL DROP TABLE dbo.Technicians;

-- 3. OWNERS TABLE

CREATE TABLE Owners (
    OwnerID INT PRIMARY KEY IDENTITY(1,1),
    FullName NVARCHAR(100) NOT NULL,
    ContactNumber NVARCHAR(15) NOT NULL,
    Email NVARCHAR(100) UNIQUE,
    CreatedAt DATETIME DEFAULT GETDATE()
);

-- 4. TECHNICIANS TABLE
-- To track which team member is assigned to a specific recovery.
CREATE TABLE Technicians (
    TechID INT PRIMARY KEY IDENTITY(1,1),
    TechName NVARCHAR(100) NOT NULL,
    Expertise NVARCHAR(50), -- e.g., 'EV specialist', 'Heavy Towing'
    IsAvailable BIT DEFAULT 1
);

-- 5. VEHICLES TABLE
-- The core entity for the "Track" class in your C# code.
CREATE TABLE Vehicles (
    VehicleID INT PRIMARY KEY IDENTITY(1,1),
    LicensePlate NVARCHAR(15) NOT NULL UNIQUE, -- Unique constraint for searches
    Make NVARCHAR(50) NOT NULL,
    Model NVARCHAR(50) NOT NULL,
    Color NVARCHAR(20),
    OwnerID INT NOT NULL,
    CONSTRAINT FK_Vehicle_Owner FOREIGN KEY (OwnerID) REFERENCES Owners(OwnerID) 
        ON DELETE CASCADE
);

-- 6. RECOVERY JOBS TABLE
-- This links the Vehicle, Technician, and the specific Issue.
CREATE TABLE RecoveryJobs (
    JobID INT PRIMARY KEY IDENTITY(1,1),
    VehicleID INT NOT NULL,
    TechID INT NOT NULL,
    IssueDescription NVARCHAR(MAX) NOT NULL,
    LocationDescription NVARCHAR(255),
    JobStatus NVARCHAR(20) DEFAULT 'Pending' 
        CHECK (JobStatus IN ('Pending', 'Dispatched', 'In Progress', 'Completed', 'Cancelled')),
    PriorityLevel INT DEFAULT 1, -- 1=Low, 5=Emergency
    LogDate DATETIME DEFAULT GETDATE(),
    
    CONSTRAINT FK_Job_Vehicle FOREIGN KEY (VehicleID) REFERENCES Vehicles(VehicleID),
    CONSTRAINT FK_Job_Tech FOREIGN KEY (TechID) REFERENCES Technicians(TechID)
);

-- 7. PERFORMANCE INDEXING (Critical for "Search Functionality" marks)
-- These indexes allow the database to search thousands of records instantly.
CREATE INDEX IX_Vehicles_LicensePlate ON Vehicles(LicensePlate);
CREATE INDEX IX_RecoveryJobs_Status ON RecoveryJobs(JobStatus);

